<%- include('partials/header', { title: 'Dashboard — Gestão de Obra' }) %>

<div class="mb-6 flex flex-wrap items-end justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold text-slate-800">Painel do Prédio</h1>
    <p class="text-slate-500 text-sm mt-1">
      <%= numFloors %> andares · <%= aptsPerFloor %> apartamentos por andar
    </p>
  </div>
  <div class="bg-white rounded-xl shadow-sm px-5 py-3 flex items-center gap-4 min-w-[240px]">
    <div class="flex-1">
      <div class="flex justify-between text-xs text-slate-500 mb-1">
        <span>Progresso geral do prédio</span>
        <span class="font-bold text-slate-700"><%= overallPct %>%</span>
      </div>
      <div class="w-full bg-slate-200 rounded-full h-2.5">
        <div class="h-2.5 rounded-full transition-all
          <%= overallPct === 100 ? 'bg-green-500' : overallPct >= 50 ? 'bg-blue-500' : 'bg-yellow-400' %>"
          style="width:<%= overallPct %>%"></div>
      </div>
      <p class="text-xs text-slate-400 mt-1"><%= overallDone %> / <%= overallTotal %> tarefas</p>
    </div>
  </div>
</div>

<!-- ── Filtro por Tarefa ──────────────────────────────────────────────── -->
<div class="bg-white rounded-xl shadow-sm px-5 py-4 mb-5">
  <h2 class="text-sm font-semibold text-slate-700 mb-3">🔍 Filtrar por Tarefa</h2>
  <div class="flex flex-wrap gap-3 items-end">
    <div class="flex-1 min-w-[200px]">
      <label class="text-xs text-slate-500 mb-1 block">Selecione a tarefa</label>
      <select id="task-select"
              class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm text-slate-700
                     focus:outline-none focus:ring-2 focus:ring-blue-400 bg-white">
        <option value="">-- escolha uma tarefa --</option>
        <% for (const t of allTasks) { %>
        <option value="<%= t %>"><%= t %></option>
        <% } %>
      </select>
    </div>
    <button onclick="applyTaskFilter()"
            class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium
                   px-5 py-2 rounded-lg transition">
      Filtrar
    </button>
    <button onclick="clearTaskFilter()"
            class="bg-slate-200 hover:bg-slate-300 text-slate-700 text-sm font-medium
                   px-4 py-2 rounded-lg transition">
      Limpar
    </button>
  </div>

  <!-- Resultado do filtro -->
  <div id="filter-results" class="hidden mt-4">
    <div class="flex items-center justify-between mb-3">
      <span id="filter-title" class="text-sm font-semibold text-slate-700"></span>
      <!-- Legenda de status -->
      <div class="flex flex-wrap gap-2 text-xs">
        <span class="flex items-center gap-1">
          <span class="w-4 h-4 rounded bg-slate-200 border border-slate-400 inline-block"></span>N
        </span>
        <span class="flex items-center gap-1">
          <span class="w-4 h-4 rounded bg-blue-200 border border-blue-400 inline-block"></span>I
        </span>
        <span class="flex items-center gap-1">
          <span class="w-4 h-4 rounded bg-yellow-200 border border-yellow-400 inline-block"></span>A
        </span>
        <span class="flex items-center gap-1">
          <span class="w-4 h-4 rounded bg-green-400 border border-green-600 inline-block"></span>C
        </span>
        <span class="flex items-center gap-1">
          <span class="w-4 h-4 rounded bg-purple-200 border border-purple-400 inline-block"></span>R
        </span>
        <span class="flex items-center gap-1">
          <span class="w-4 h-4 rounded bg-white border border-dashed border-slate-300 inline-block"></span>N/A
        </span>
      </div>
    </div>
    <div id="filter-grid" class="space-y-2"></div>
  </div>
</div>

<!-- ── Legenda de progresso ───────────────────────────────────────────── -->
<div class="flex flex-wrap items-center gap-3 text-xs text-slate-600 mb-5 bg-white rounded-lg shadow-sm px-4 py-2">
  <span class="font-semibold">Legenda:</span>
  <span class="flex items-center gap-1"><span class="w-4 h-4 rounded bg-slate-200 border border-slate-300 inline-block"></span>0%</span>
  <span class="flex items-center gap-1"><span class="w-4 h-4 rounded bg-yellow-300 border border-yellow-400 inline-block"></span>1–49%</span>
  <span class="flex items-center gap-1"><span class="w-4 h-4 rounded bg-orange-400 border border-orange-500 inline-block"></span>50–79%</span>
  <span class="flex items-center gap-1"><span class="w-4 h-4 rounded bg-green-300 border border-green-400 inline-block"></span>80–99%</span>
  <span class="flex items-center gap-1"><span class="w-4 h-4 rounded bg-green-500 border border-green-600 inline-block"></span>100%</span>
</div>

<!-- ── Grade de andares ───────────────────────────────────────────────── -->
<div class="space-y-2">
<% for (const floorInfo of floorData) { %>
  <div class="bg-white rounded-xl shadow-sm px-4 py-3">
    <div class="flex items-start gap-3">
      <div class="w-16 flex-shrink-0 text-center">
        <span class="text-sm font-bold text-slate-700"><%= floorInfo.floor %>º</span>
        <div class="text-xs text-slate-400">Andar</div>
      </div>
      <div class="flex flex-wrap gap-1.5">
      <% for (const apt of floorInfo.apartments) { %>
        <%
          let cellCls;
          if      (apt.pct === 100) cellCls = "bg-green-500 text-white border-green-600";
          else if (apt.pct >= 80)   cellCls = "bg-green-200 text-green-900 border-green-300";
          else if (apt.pct >= 50)   cellCls = "bg-orange-400 text-white border-orange-500";
          else if (apt.pct > 0)     cellCls = "bg-yellow-300 text-yellow-900 border-yellow-400";
          else                       cellCls = "bg-slate-100 text-slate-500 border-slate-300";
        %>
        <a href="/apartment/<%= floorInfo.floor %>/<%= apt.number %>"
           title="Apt <%= floorInfo.floor * 100 + apt.number %> · Tipo <%= apt.apt_type %> · <%= apt.pct %>% (<%= apt.completed %>/<%= apt.total %>)"
           class="w-11 h-11 rounded-lg border flex flex-col items-center justify-center cursor-pointer
                  hover:ring-2 hover:ring-blue-400 hover:scale-105 transition-all text-center <%= cellCls %>">
          <span class="text-xs font-bold leading-tight"><%= apt.number %></span>
          <span class="text-[10px] opacity-80 leading-tight"><%= apt.apt_type %></span>
        </a>
      <% } %>
      </div>
    </div>
  </div>
<% } %>
</div>

<%- include('partials/footer', { extraScript: `
<script>
const STATUS_CLS = {
  N: "bg-slate-200 border-slate-400 text-slate-600",
  I: "bg-blue-200 border-blue-400 text-blue-800",
  A: "bg-yellow-200 border-yellow-400 text-yellow-800",
  C: "bg-green-400 border-green-600 text-white",
  R: "bg-purple-200 border-purple-400 text-purple-800",
};

async function applyTaskFilter() {
  const task = document.getElementById("task-select").value;
  if (!task) return;

  const r    = await fetch("/api/task-filter?task=" + encodeURIComponent(task));
  const data = await r.json();

  const resultsDiv = document.getElementById("filter-results");
  const titleEl    = document.getElementById("filter-title");
  const gridEl     = document.getElementById("filter-grid");

  titleEl.textContent = "Tarefa: " + task;

  let html = "";
  for (const floorInfo of data.floors) {
    html += '<div class="bg-slate-50 rounded-lg px-3 py-2 flex items-start gap-3">';
    html += '<div class="w-16 flex-shrink-0 text-center"><span class="text-sm font-bold text-slate-700">'
          + floorInfo.floor + 'º</span><div class="text-xs text-slate-400">Andar</div></div>';
    html += '<div class="flex flex-wrap gap-1.5">';

    for (const apt of floorInfo.apartments) {
      const displayNum = floorInfo.floor * 100 + apt.number;
      const link = "/apartment/" + floorInfo.floor + "/" + apt.number;

      if (apt.status === null) {
        // tarefa não existe neste tipo de apartamento
        html += '<a href="' + link + '" title="Apt ' + displayNum + ' — N/A (tarefa não aplicável)"'
              + ' class="w-11 h-11 rounded-lg border border-dashed border-slate-300 bg-white'
              + ' flex flex-col items-center justify-center text-slate-300 text-[10px] hover:ring-2'
              + ' hover:ring-blue-400 hover:scale-105 transition-all">'
              + '<span class="text-xs font-bold leading-tight text-slate-400">' + apt.number + '</span>'
              + '<span class="text-[9px]">N/A</span></a>';
      } else {
        const cls = STATUS_CLS[apt.status] || STATUS_CLS.N;
        html += '<a href="' + link + '" title="Apt ' + displayNum + ' — ' + apt.status + '"'
              + ' class="w-11 h-11 rounded-lg border flex flex-col items-center justify-center'
              + ' hover:ring-2 hover:ring-blue-400 hover:scale-105 transition-all ' + cls + '">'
              + '<span class="text-xs font-bold leading-tight">' + apt.number + '</span>'
              + '<span class="text-[10px] font-bold">' + apt.status + '</span></a>';
      }
    }

    html += "</div></div>";
  }

  gridEl.innerHTML = html;
  resultsDiv.classList.remove("hidden");
  resultsDiv.scrollIntoView({ behavior: "smooth", block: "start" });
}

function clearTaskFilter() {
  document.getElementById("task-select").value = "";
  document.getElementById("filter-results").classList.add("hidden");
}
</script>
` }) %>
