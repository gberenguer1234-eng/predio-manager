<%- include('partials/header', { title: `Apto ${number} · ${floor}º Andar` }) %>

<!-- Header -->
<div class="flex flex-wrap items-start justify-between gap-4 mb-5">
  <div>
    <nav class="text-xs text-slate-400 mb-1">
      <a href="/" class="hover:text-slate-600">Dashboard</a>
      <span class="mx-1">/</span>
      <span><%= floor %>º Andar · Apt <%= displayNum %></span>
    </nav>
    <h1 class="text-2xl font-bold text-slate-800">
      Apt&nbsp;<span class="text-blue-700"><%= displayNum %></span>
      &nbsp;<span class="text-slate-400 font-normal text-lg">·</span>&nbsp;
      <%= floor %>º Andar
    </h1>
    <div class="flex flex-wrap items-center gap-4 mt-1 text-sm text-slate-500">
      <span>
        Tipo:
        <select id="type-select" onchange="updateType(this.value)"
                class="font-semibold text-blue-600 bg-transparent border-none cursor-pointer focus:outline-none">
          <% for (const t of aptTypes) { %>
          <option value="<%= t %>" <%= t === apt.apt_type ? 'selected' : '' %>><%= t %></option>
          <% } %>
        </select>
      </span>
      <span id="progress-label"><%= completed %>/<%= total %> tarefas concluídas (<%= pct %>%)</span>
    </div>
  </div>
  <div class="flex flex-wrap gap-2">
    <label class="cursor-pointer inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700
                  text-white text-sm font-medium px-4 py-2 rounded-lg transition">
      📷 Ler Foto
      <input type="file" id="photo-input" accept="image/*,image/heic" class="hidden"
             onchange="uploadPhoto(this)">
    </label>
    <a href="/print/<%= floor %>/<%= number %>?blank=true" target="_blank"
       class="inline-flex items-center gap-2 bg-slate-600 hover:bg-slate-700
              text-white text-sm font-medium px-4 py-2 rounded-lg transition">
      📋 Gabarito
    </a>
    <a href="/print/<%= floor %>/<%= number %>" target="_blank"
       class="inline-flex items-center gap-2 bg-slate-800 hover:bg-slate-900
              text-white text-sm font-medium px-4 py-2 rounded-lg transition">
      🖨️ Status atual
    </a>
  </div>
</div>

<!-- Overall progress bar -->
<div class="bg-white rounded-xl shadow-sm px-5 py-4 mb-5">
  <div class="flex justify-between text-sm mb-2">
    <span class="text-slate-600 font-medium">Progresso Geral</span>
    <span class="font-bold text-slate-800" id="pct-label"><%= pct %>%</span>
  </div>
  <div class="w-full bg-slate-200 rounded-full h-3">
    <div id="progress-bar"
         class="h-3 rounded-full transition-all duration-500
                <%= pct === 100 ? 'bg-green-500' : pct >= 50 ? 'bg-blue-500' : 'bg-yellow-400' %>"
         style="width:<%= pct %>%"></div>
  </div>
  <!-- Mini bars per environment -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mt-3">
  <% for (const env of environments) { %>
    <button onclick="showTab('<%= env.id %>')"
            class="text-left p-2 rounded-lg hover:bg-slate-50 transition border border-slate-100">
      <div class="flex justify-between text-xs text-slate-500 mb-1">
        <span><%= env.emoji %> <%= env.name.length > 14 ? env.name.substring(0,13)+'…' : env.name %></span>
        <span id="mini-<%= env.id %>"><%= env.completed %>/<%= env.total %></span>
      </div>
      <div class="w-full bg-slate-200 rounded-full h-1">
        <div id="minibar-<%= env.id %>" class="h-1 rounded-full bg-blue-400"
             style="width:<%= env.total > 0 ? Math.floor(env.completed/env.total*100) : 0 %>%"></div>
      </div>
    </button>
  <% } %>
  </div>
</div>

<!-- Upload message -->
<div id="upload-msg" class="hidden mb-4 p-3 rounded-lg text-sm font-medium"></div>

<!-- Notes -->
<div class="bg-white rounded-xl shadow-sm px-5 py-3 mb-5">
  <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Observações</label>
  <textarea id="notes-area" rows="2"
            placeholder="Ex: pendências, acesso restrito, data da última vistoria…"
            class="w-full mt-1 text-sm text-slate-700 border-none focus:outline-none resize-none bg-transparent"
            onblur="saveNotes(this.value)"><%= apt.notes %></textarea>
</div>

<!-- Tabs -->
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <div class="flex overflow-x-auto border-b border-slate-200 bg-slate-50" id="tab-bar">
  <% environments.forEach((env, idx) => { %>
    <button onclick="showTab('<%= env.id %>')"
            id="tab-<%= env.id %>"
            class="tab-btn flex-shrink-0 px-4 py-3 text-sm font-medium border-b-2 transition
                   flex items-center gap-1.5 whitespace-nowrap
                   <%= idx === 0 ? 'border-blue-500 text-blue-600 bg-white' : 'border-transparent text-slate-500 hover:text-slate-700' %>">
      <span><%= env.emoji %></span>
      <span class="hidden sm:inline"><%= env.name %></span>
      <span id="tab-count-<%= env.id %>"
            class="text-xs px-1.5 py-0.5 rounded-full
                   <%= env.completed === env.total ? 'bg-green-100 text-green-700' : env.completed > 0 ? 'bg-blue-100 text-blue-700' : 'bg-slate-200 text-slate-500' %>">
        <%= env.completed %>/<%= env.total %>
      </span>
    </button>
  <% }) %>
  </div>

  <!-- Panels -->
  <% environments.forEach((env, idx) => { %>
  <div id="panel-<%= env.id %>" class="env-panel <%= idx !== 0 ? 'hidden' : '' %> p-4">

    <div class="flex items-center justify-between mb-3">
      <span class="font-semibold text-slate-700"><%= env.emoji %> <%= env.name %></span>
      <div class="flex items-center gap-3">
        <button onclick="markAllEnv('<%= env.id %>', 'C')"
                class="text-xs text-slate-400 hover:text-green-600 transition">✓ Tudo concluído</button>
        <button onclick="markAllEnv('<%= env.id %>', 'N')"
                class="text-xs text-slate-400 hover:text-red-400 transition">✕ Zerar tudo</button>
      </div>
    </div>

    <!-- Legend -->
    <div class="flex flex-wrap items-center gap-2 text-xs mb-3">
    <% for (const [sKey, sInfo] of Object.entries(STATUS)) { %>
      <span class="px-2 py-0.5 rounded font-bold border"
            style="background:<%= sInfo.bg %>;border-color:<%= sInfo.border %>;color:<%= sInfo.color %>">
        <%= sKey %> = <%= sInfo.label %>
      </span>
    <% } %>
    </div>

    <!-- Tasks -->
    <div class="divide-y divide-slate-100">
    <% for (const task of env.tasks) { %>
      <div class="flex items-center gap-2 py-1.5 px-1 hover:bg-slate-50 rounded transition"
           id="row-<%= env.id %>-<%= task.index %>">
        <span class="text-[11px] text-slate-300 w-5 text-right flex-shrink-0 select-none">
          <%= task.index + 1 %>
        </span>
        <span class="flex-1 text-sm text-slate-700"><%= task.name %></span>
        <div class="flex gap-1 flex-shrink-0">
        <% for (const [sKey, sInfo] of Object.entries(STATUS)) { %>
          <button id="btn-<%= env.id %>-<%= task.index %>-<%= sKey %>"
                  onclick="setStatus(<%= apt.id %>, '<%= env.id %>', <%= task.index %>, '<%= sKey %>')"
                  class="status-btn w-8 h-7 rounded text-xs font-bold border transition"
                  style="
                    <% if (task.status === sKey) { %>
                      background:<%= sInfo.bg %>;border-color:<%= sInfo.border %>;color:<%= sInfo.color %>;
                      outline:2px solid <%= sInfo.border %>;outline-offset:1px;
                    <% } else { %>
                      background:white;border-color:#e2e8f0;color:#cbd5e1;
                    <% } %>
                  ">
            <%= sKey %>
          </button>
        <% } %>
        </div>
      </div>
    <% } %>
    </div>
  </div>
  <% }) %>
</div>

<%- include('partials/footer', {
  extraScript: `<script>
    const APT_ID = ${apt.id};
    const FLOOR  = ${floor};
    const NUMBER = ${number};
    const ENV_TOTALS = {${environments.map(e => `"${e.id}":${e.total}`).join(',')}};
  </script>`
}) %>
